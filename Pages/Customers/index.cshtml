@page
@model CRMProject.Pages.Customer.index
@{
    ViewData["Title"] = "Customers List";
}

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-people-fill"></i> @ViewData["Title"]
        </h2>

        <a asp-page="/Customers/Create" class="btn btn-success shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Create New Customer
        </a>
    </div>

    <!-- Customer Table Card -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            <table class="table table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var customer in Model.listCustomers)
                    {
                        <tr>
                            <td>@customer.Id</td>
                            <td class="fw-semibold">@customer.Name</td>
                            <td>@customer.Email</td>
                            <td>@customer.Phone</td>

                            <td>
                                <a href="/Customers/Edit?id=@customer.Id"
                                   class="btn btn-sm btn-outline-primary me-2">
                                    Edit
                                </a>

                                <a href="/Customers/Delete?id=@customer.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>