@page
@model CRMProject.Pages.Customers.Delete

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container mt-5 d-flex justify-content-center">

    <!-- Delete Card -->
    <div class="card shadow-lg border-0 rounded-3" style="width:420px;">

        <div class="card-body text-center p-4">

            <!-- Warning Icon -->
            <div class="mb-3">
                <i class="bi bi-exclamation-triangle-fill text-danger"
                   style="font-size: 3rem;"></i>
            </div>

            <h3 class="fw-bold text-danger mb-3">
                Delete Customer
            </h3>

            <p class="text-muted">
                Are you sure you want to delete this customer?
                This action cannot be undone.
            </p>

            <!-- Customer Info -->
            <div class="alert alert-light border">
                <strong>Customer ID :</strong> @Model.CustId
            </div>

            <form method="post">

                <input type="hidden" asp-for="CustId" />

                <div class="d-flex justify-content-center gap-3 mt-3">

                    <a asp-page="/Customers/Index"
                       class="btn btn-outline-secondary px-4">
                        Cancel
                    </a>

                    <button type="submit"
                            class="btn btn-danger px-4">
                        Delete
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>